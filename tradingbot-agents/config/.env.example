# ─────────────────────────────────────────────────────────────────────────────
# TradingBot Environment Configuration
# Copy to .env in swing_bot/ — NEVER commit the real .env file
# Must match swing_bot/config/settings.py variable names and allowed values
# ─────────────────────────────────────────────────────────────────────────────

# ── Core (required) ─────────────────────────────────────────────────────────
# ENVIRONMENT: demo | live
ENVIRONMENT=demo

# EXCHANGE: delta_demo | coinswitch_live
EXCHANGE=delta_demo

# PROFILE: ltf_5m | ltf_15m
PROFILE=ltf_5m

# ── Symbols ─────────────────────────────────────────────────────────────────
DEMO_SYMBOL=XRPUSD
LIVE_SYMBOL=ADAUSDT
# SYMBOL=              # Optional legacy override — leave blank to auto-select

# ── Risk & Capital ──────────────────────────────────────────────────────────
LEVERAGE=3                        # 1–20
USE_FIXED_CAPITAL=true
FIXED_CAPITAL_INR=1000.0          # Must be > 0
RISK_PER_TRADE_PERCENT=2.0        # Must be > 0
INR_TO_USDT_RATE=0.012            # 1 INR ≈ 0.012 USDT (~83 INR/USDT)

# ── Session Windows (UTC) ──────────────────────────────────────────────────
LONDON_PEAK_START_UTC=07:00
LONDON_PEAK_END_UTC=10:00
OVERLAP_START_UTC=13:00
OVERLAP_END_UTC=16:00
NY_PEAK_START_UTC=17:00
NY_PEAK_END_UTC=20:00
SESSION_ONLY_TRADING=true

# ── Session RR Ratios ──────────────────────────────────────────────────────
RR_LONDON=2.0
RR_OVERLAP=4.0
RR_NY=3.0

# ── Strategy Parameters ────────────────────────────────────────────────────
ENTRY_PERCENT=50.0
PIVOT_LEFT_BARS=5
PIVOT_RIGHT_BARS=5
ATR_PERIOD=14
DISPLACEMENT_MULT_5M=1.8
DISPLACEMENT_MULT_15M=1.5
MAX_FVG_AGE_5M=24
MAX_FVG_AGE_15M=20
DISPLACEMENT_LOOKBACK=50          # Must be > 0

# ── Fee Configuration ──────────────────────────────────────────────────────
DELTA_MAKER_FEE_PERCENT=0.05
DELTA_TAKER_FEE_PERCENT=0.02
COINSWITCH_TRADING_FEE_PERCENT=0.20
COINSWITCH_TDS_PERCENT=1.00
COINSWITCH_TOTAL_COST_PERCENT=1.20

# ── Data & Runtime ─────────────────────────────────────────────────────────
DATA_SOURCE_PRIMARY=exchange_futures
DATA_SOURCE_FALLBACK=binance_usdm_futures
CANDLE_LIMIT=300
CANDLE_CLOSE_BUFFER_SECONDS=5
MAX_RETRIES=3
RETRY_BASE_DELAY_SECONDS=1.0
RETRY_JITTER_PERCENT=20.0

# ── Reconciliation ─────────────────────────────────────────────────────────
RECONCILE_INTERVAL_SECONDS=30

# ── Trailing Stop-Loss ─────────────────────────────────────────────────────
TRAILING_SL_ENABLED=true
ATR_TRAIL_MULT=1.5

# ── Secrets (required) ─────────────────────────────────────────────────────
# Delta Exchange demo/testnet
DELTA_DEMO_API_KEY=your_delta_demo_api_key_here
DELTA_DEMO_API_SECRET=your_delta_demo_api_secret_here

# CoinSwitch Pro live — WARNING: real money
COINSWITCH_API_KEY=your_coinswitch_api_key_here
COINSWITCH_API_SECRET=your_coinswitch_api_secret_here

# Telegram alerts (required)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Storage & Logging ──────────────────────────────────────────────────────
SQLITE_PATH=swing_bot.db
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
