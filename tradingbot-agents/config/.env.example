# ─────────────────────────────────────────────────────────────────────────────
# TradingBot Environment Configuration
# Copy to config/delta.env OR config/coinswitch.env — NEVER commit either file
# ─────────────────────────────────────────────────────────────────────────────

# ── Which exchange this instance connects to ──────────────────────────────────
# Options: delta | coinswitch
EXCHANGE=delta

# ── Trading Pair ──────────────────────────────────────────────────────────────
# Delta:      ADAUSD    (USD-margined inverse perpetual)
# CoinSwitch: ADAUSDT or XRPUSDT (USDT-margined linear perpetual)
TRADING_PAIR=ADAUSD

# ── Instance Mode ─────────────────────────────────────────────────────────────
# validation = Delta Exchange ADA validation instance
# live       = CoinSwitch live trading instance
INSTANCE_MODE=validation

# ── Delta Exchange API (paper/validation) ─────────────────────────────────────
DELTA_API_KEY=your_delta_api_key_here
DELTA_API_SECRET=your_delta_api_secret_here
DELTA_BASE_URL=https://api.delta.exchange
DELTA_WS_URL=wss://socket.delta.exchange

# ── CoinSwitch Pro API (live trading) ─────────────────────────────────────────
# WARNING: These keys control real money. IP-restrict them in CoinSwitch settings.
COINSWITCH_API_KEY=your_coinswitch_api_key_here
COINSWITCH_API_SECRET=your_coinswitch_api_secret_here
COINSWITCH_BASE_URL=https://coinswitch.co/pro/api
COINSWITCH_WS_URL=wss://ws.coinswitch.co

# ── Risk Management ───────────────────────────────────────────────────────────
MAX_RISK_PER_TRADE_PCT=1.0
MAX_DAILY_DRAWDOWN_PCT=5.0
MAX_WEEKLY_DRAWDOWN_PCT=10.0
MAX_OPEN_POSITIONS=1          # 1 per instance (ADA bot or XRP bot — not both)

# ── Strategy Timeframes ───────────────────────────────────────────────────────
HTF_TIMEFRAME=4h
ITF_TIMEFRAME=1h
LTF_TIMEFRAME=15m

# ── ADA Specific ──────────────────────────────────────────────────────────────
ADA_OB_MIN_MOVE_MULTIPLIER=1.5
ADA_FVG_MIN_GAP_PCT=0.05
ADA_OB_MAX_VISITS=2
ADA_LIQUIDITY_TOLERANCE_PCT=0.03

# ── XRP Specific ──────────────────────────────────────────────────────────────
XRP_OB_MIN_MOVE_MULTIPLIER=2.0
XRP_FVG_MIN_GAP_PCT=0.08
XRP_OB_MAX_VISITS=1
XRP_LIQUIDITY_TOLERANCE_PCT=0.05
XRP_NEWS_FILTER_ENABLED=true
XRP_NEWS_PAUSE_MINUTES=30      # Pause XRP trading N min around news events

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://trader:password@localhost:5432/tradingbot
REDIS_URL=redis://localhost:6379/0

# ── Telegram Alerts ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_private_chat_id

# ── API Dashboard ─────────────────────────────────────────────────────────────
API_PORT=8000
API_SECRET_KEY=generate_strong_random_secret

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/tradingbot.log
